# =============================================
# Landing for Portfolio — Environment Variables
# Скопіюй у .env і заповни своїми значеннями
# =============================================

# Database
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=landing_for_portfolio
MYSQL_USER=wp_user
MYSQL_PASSWORD=wp_password

# WordPress
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=landing_for_portfolio
WORDPRESS_DB_USER=wp_user
WORDPRESS_DB_PASSWORD=wp_password

# Site URLs
WP_HOME=http://localhost:8082
WP_SITEURL=http://localhost:8082
